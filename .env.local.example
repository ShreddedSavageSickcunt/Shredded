# Copy this file to ".env.local" and fill in the values from your Supabase project.
# Supabase Dashboard -> Project Settings -> API

# Your project URL, e.g. https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Your "anon" public API key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Name of the Supabase Storage bucket used for check-in photos.
NEXT_PUBLIC_SUPABASE_PHOTO_BUCKET=checkin-photos
