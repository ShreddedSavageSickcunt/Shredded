# Copy this file to ".env.local" and fill in the values from your Supabase project.
# Supabase Dashboard -> Project Settings -> API

# Your project URL, e.g. https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Your "anon" public API key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Name of the Supabase Storage bucket used for check-in photos.
NEXT_PUBLIC_SUPABASE_PHOTO_BUCKET=checkin-photos

# --- Check-in reminder emails (the daily /api/remind cron) ---
# Resend API key (https://resend.com -> API Keys)
RESEND_API_KEY=
# Verified sender, e.g. "Shredded <reminders@yourdomain.com>"
REMINDER_FROM_EMAIL=
# Shared secret Vercel Cron sends as a Bearer token to protect the endpoint.
CRON_SECRET=
# Optional: recommended server-only key so the cron isn't reading emails via the
# public anon key. Supabase Dashboard -> Project Settings -> API -> service_role.
SUPABASE_SERVICE_ROLE_KEY=
# Optional: override the app URL used in the email's "Check in" button.
REMINDER_APP_URL=
